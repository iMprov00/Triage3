<%# locals: step_key — номер шага (1–3) или 'actions' для действий приоритета %>
<% sk = step_key %>
<% selected = current_user.id.to_i %>
<% if can_choose_step_performer? %>
  <div class="app-card card mb-3 border-secondary-subtle">
    <div class="app-card-header card-header py-2">
      <span class="text-muted small text-uppercase fw-normal">Исполнитель при сохранении</span>
    </div>
    <div class="card-body py-2">
      <label class="form-label small mb-1" for="step-performer-<%= sk %>">Кто выполняет / подтверждает</label>
      <select name="step_performer_user_id" id="step-performer-<%= sk %>" class="form-select form-select-sm">
        <% step_performer_users_for_select.each do |u| %>
          <option value="<%= u.id %>" <%= 'selected' if u.id == selected %>><%= Rack::Utils.escape_html(u.full_name) %> — <%= u.position_label %></option>
        <% end %>
      </select>
    </div>
  </div>
<% else %>
  <input type="hidden" name="step_performer_user_id" value="<%= current_user.id %>">
<% end %>
