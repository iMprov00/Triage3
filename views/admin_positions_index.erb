<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
  <div>
    <h1 class="page-title mb-0">Должности</h1>
    <p class="text-muted small mb-0">Справочник для назначения пользователям. Тип определяет права в системе.</p>
  </div>
  <div class="action-bar">
    <a href="/admin/positions/new" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Новая должность</a>
    <a href="/admin/users" class="btn btn-outline-secondary">Пользователи</a>
    <a href="/patients" class="btn btn-outline-secondary">К списку пациентов</a>
  </div>
</div>

<div class="alert alert-info small mb-4">
  <strong>Тип «Администратор»</strong> — доступ к разделам «Пользователи» и «Должности», выбор исполнителя.<br>
  <strong>Тип «Врач»</strong> — выбор исполнителя на карте и этапах триажа.<br>
  <strong>Тип «Прочее»</strong> — исполнитель по умолчанию только сам пользователь.
</div>

<div class="app-card card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0 small">
        <thead class="table-light">
          <tr>
            <th>Название</th>
            <th>Тип</th>
            <th>Пользователей</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @positions.each do |p| %>
            <tr>
              <td><%= Rack::Utils.escape_html(p.name) %></td>
              <td><span class="text-muted"><%= Rack::Utils.escape_html(p.short_kind_label) %></span></td>
              <td><%= p.users.size %></td>
              <td class="text-end text-nowrap">
                <a href="/admin/positions/<%= p.id %>/edit" class="btn btn-sm btn-outline-primary">Изменить</a>
                <% if p.users.empty? %>
                  <form method="post" action="/admin/positions/<%= p.id %>/delete" class="d-inline" onsubmit="return confirm('Удалить должность «<%= Rack::Utils.escape_html(p.name).gsub("'", '&#39;') %>»?');">
                    <button type="submit" class="btn btn-sm btn-outline-danger">Удалить</button>
                  </form>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
