<%# Шаг 1: уровень сознания %>
<% s1 = @triage.step1_data || {} %>
<% breathing_default_yes = s1['breathing'] != false %>
<% heartbeat_default_yes = s1['heartbeat'] != false %>
<div class="row align-items-start mb-2">
  <div class="col-12 col-md-8">
    <h1 class="page-title">Шаг 1 — <%= @patient.full_name %></h1>
    <p class="text-muted small mb-0">Уровень сознания · 2 мин</p>
  </div>
  <div class="col-12 col-md-4 mb-3 mb-md-0">
    <div id="triage-timer" class="timer-box <%= @triage.expired? ? 'timer-expired' : 'timer-running' %> mb-3">
      <h4 class="text-center mb-0">
        <i class="bi bi-clock"></i>
        <span id="timer-display"><%= @triage.time_remaining %></span> сек
      </h4>
    </div>
    <div id="consciousness-score-panel" class="alert triage-score-panel alert-success mb-0 d-none d-md-block">
      <strong class="d-block">Сумма баллов: <span id="total-score">0</span></strong>
      <div class="small text-muted mt-1">Красный приоритет: сумма ≤ 8 баллов, судороги или активное кровотечение</div>
    </div>
  </div>
</div>

<div id="time-expired-warning" class="alert alert-warning <%= @triage.expired? ? '' : 'd-none' %>">
  <h4><i class="bi bi-exclamation-triangle"></i> Время вышло!</h4>
  <p class="mb-0 small">Таймер шага истёк, но вы можете продолжить заполнение формы.</p>
</div>

<form id="triage-form" action="/patients/<%= @patient.id %>/triage/step1" method="post" class="mt-4">
  <div class="app-card card mb-4">
    <div class="app-card-header card-header">
      <span class="text-muted small text-uppercase fw-normal">Уровень сознания</span>
    </div>
    <div class="card-body">
      <div class="row g-3">
        <div class="col-md-4">
          <label class="form-label">Открывание глаз</label>
          <select name="eye_opening" class="form-select triage-score-field" required>
            <option value="">Выберите...</option>
            <% Triage::EYE_OPENING_SCORES.each do |text, score| %>
              <option value="<%= text %>"><%= text %> (<%= score %> баллов)</option>
            <% end %>
          </select>
        </div>

        <div class="col-md-4">
          <label class="form-label">Речевые реакции</label>
          <select name="verbal_response" class="form-select triage-score-field" required>
            <option value="">Выберите...</option>
            <% Triage::VERBAL_SCORES.each do |text, score| %>
              <option value="<%= text %>"><%= text %> (<%= score %> баллов)</option>
            <% end %>
          </select>
        </div>

        <div class="col-md-4">
          <label class="form-label">Двигательные реакции</label>
          <select name="motor_response" class="form-select triage-score-field" required>
            <option value="">Выберите...</option>
            <% Triage::MOTOR_SCORES.each do |text, score| %>
              <option value="<%= text %>"><%= text %> (<%= score %> баллов)</option>
            <% end %>
          </select>
        </div>
      </div>
      <div class="d-md-none mt-3">
        <div id="consciousness-score-panel-mobile" class="alert triage-score-panel alert-success mb-0">
          <strong class="d-block">Сумма баллов: <span id="total-score-mobile">0</span></strong>
          <div class="small text-muted mt-1">Красный приоритет: сумма ≤ 8 баллов, судороги или активное кровотечение</div>
        </div>
      </div>
    </div>
  </div>

  <div class="app-card card mb-4">
    <div class="app-card-header card-header">
      <span class="text-muted small text-uppercase fw-normal">Витальные функции и кровотечение</span>
    </div>
    <div class="card-body">
      <div class="row g-4 align-items-start">
        <div class="col-12 col-md-6 triage-step1-split-left pb-3 pb-md-0 border-bottom border-md-0">
          <div class="text-muted small text-uppercase fw-semibold mb-3">Витальные функции</div>
          <div class="triage-step1-vitals">
            <div class="mb-3">
              <label class="form-label d-block">Дыхание</label>
              <div class="btn-group" role="group">
                <input type="radio" class="btn-check" name="breathing" id="breathing_yes" value="true" autocomplete="off" <%= 'checked' if breathing_default_yes %>>
                <label class="btn btn-outline-secondary triage-vitals-yes" for="breathing_yes">Да</label>
                <input type="radio" class="btn-check" name="breathing" id="breathing_no" value="false" autocomplete="off" <%= 'checked' unless breathing_default_yes %>>
                <label class="btn btn-outline-secondary triage-vitals-no" for="breathing_no">Нет</label>
              </div>
            </div>
            <div class="mb-0">
              <label class="form-label d-block">Сердцебиение</label>
              <div class="btn-group" role="group">
                <input type="radio" class="btn-check" name="heartbeat" id="heartbeat_yes" value="true" autocomplete="off" <%= 'checked' if heartbeat_default_yes %>>
                <label class="btn btn-outline-secondary triage-vitals-yes" for="heartbeat_yes">Да</label>
                <input type="radio" class="btn-check" name="heartbeat" id="heartbeat_no" value="false" autocomplete="off" <%= 'checked' unless heartbeat_default_yes %>>
                <label class="btn btn-outline-secondary triage-vitals-no" for="heartbeat_no">Нет</label>
              </div>
            </div>
          </div>
        </div>
        <div class="col-12 col-md-6 ps-md-3">
          <div class="text-muted small text-uppercase fw-semibold mb-3">Кровотечение и судороги</div>
          <div class="triage-step1-bleed">
            <div class="mb-3">
              <label class="form-label d-block">Судороги</label>
              <div class="btn-group" role="group">
                <input type="radio" class="btn-check" name="seizures" id="seizures_yes" value="true" autocomplete="off" <%= 'checked' if s1['seizures'] == true %>>
                <label class="btn btn-outline-secondary triage-bleed-yes" for="seizures_yes">Да</label>
                <input type="radio" class="btn-check" name="seizures" id="seizures_no" value="false" autocomplete="off" <%= 'checked' if s1['seizures'] != true %>>
                <label class="btn btn-outline-secondary triage-bleed-no" for="seizures_no">Нет</label>
              </div>
            </div>
            <div class="mb-0">
              <label class="form-label d-block">Активное кровотечение</label>
              <div class="btn-group" role="group">
                <input type="radio" class="btn-check" name="active_bleeding" id="active_bleeding_yes" value="true" autocomplete="off" <%= 'checked' if s1['active_bleeding'] == true %>>
                <label class="btn btn-outline-secondary triage-bleed-yes" for="active_bleeding_yes">Да</label>
                <input type="radio" class="btn-check" name="active_bleeding" id="active_bleeding_no" value="false" autocomplete="off" <%= 'checked' if s1['active_bleeding'] != true %>>
                <label class="btn btn-outline-secondary triage-bleed-no" for="active_bleeding_no">Нет</label>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%= erb :step_performer_field, locals: { step_key: 1 } %>

  <div class="d-grid gap-2 d-md-flex justify-content-md-end">
    <button type="submit" class="btn btn-success btn-lg">
      <i class="bi bi-arrow-right"></i> Далее (шаг 2)
    </button>
  </div>
</form>

<script>
(function() {
  var SCORES = {
    eye: <%= Triage::EYE_OPENING_SCORES.to_json %>,
    verbal: <%= Triage::VERBAL_SCORES.to_json %>,
    motor: <%= Triage::MOTOR_SCORES.to_json %>
  };

  function isSeizuresOrBleedingRed() {
    var s = document.querySelector('input[name="seizures"]:checked');
    var b = document.querySelector('input[name="active_bleeding"]:checked');
    return (s && s.value === 'true') || (b && b.value === 'true');
  }

  function calculateTotalScore() {
    var eyeSel = document.querySelector('select[name="eye_opening"]');
    var verbalSel = document.querySelector('select[name="verbal_response"]');
    var motorSel = document.querySelector('select[name="motor_response"]');
    var eyeText = eyeSel ? eyeSel.value : '';
    var verbalText = verbalSel ? verbalSel.value : '';
    var motorText = motorSel ? motorSel.value : '';

    var total = 0;
    if (eyeText && SCORES.eye[eyeText]) total += SCORES.eye[eyeText];
    if (verbalText && SCORES.verbal[verbalText]) total += SCORES.verbal[verbalText];
    if (motorText && SCORES.motor[motorText]) total += SCORES.motor[motorText];

    var red = total <= 8 || isSeizuresOrBleedingRed();
    var panels = document.querySelectorAll('#consciousness-score-panel, #consciousness-score-panel-mobile');
    var scoreEls = document.querySelectorAll('#total-score, #total-score-mobile');
    scoreEls.forEach(function(el) { el.textContent = total; });

    panels.forEach(function(panel) {
      if (!panel) return;
      panel.classList.remove('alert-danger', 'alert-success');
      panel.classList.add(red ? 'alert-danger' : 'alert-success');
    });
  }

  document.querySelectorAll('.triage-score-field').forEach(function(sel) {
    sel.addEventListener('change', calculateTotalScore);
    sel.addEventListener('input', calculateTotalScore);
  });
  document.querySelectorAll('input[name="seizures"], input[name="active_bleeding"]').forEach(function(r) {
    r.addEventListener('change', calculateTotalScore);
  });

  calculateTotalScore();

  var eventSource = new EventSource('/triage_events/<%= @patient.id %>');
  eventSource.onmessage = function(event) {
    var data = JSON.parse(event.data);
    var timerDisplay = document.getElementById('timer-display');
    var timerBox = document.getElementById('triage-timer');
    var warning = document.getElementById('time-expired-warning');
    if (timerDisplay) timerDisplay.textContent = data.time_remaining;
    if (timerBox) {
      timerBox.classList.toggle('timer-expired', !!data.expired);
      timerBox.classList.toggle('timer-running', !data.expired);
    }
    if (warning) {
      warning.classList.toggle('d-none', !data.expired);
    }
  };
  window.addEventListener('beforeunload', function() { eventSource.close(); });
})();
</script>
