<%# Подробная статистика по пациенту %>
<div class="row align-items-start mb-4">
  <div class="col">
    <h1 class="page-title">Статистика</h1>
    <p class="text-muted small mb-0">Журнал действий и время по шагам триажа</p>
  </div>
  <div class="col-auto">
    <a href="/patients" class="btn btn-outline-secondary"><i class="bi bi-people"></i> К списку пациентов</a>
  </div>
</div>

<div class="app-card card mb-4">
  <div class="app-card-header card-header">
    <span class="text-muted small text-uppercase fw-normal">Фильтры и выбор пациента</span>
  </div>
  <div class="card-body">
    <form method="get" action="/statistics" class="row g-3">
      <div class="col-lg-4">
        <label class="form-label">Поиск</label>
        <div class="input-group">
          <input type="text" name="search" class="form-control"
                 placeholder="ФИО, ID, исполнитель..."
                 value="<%= params[:search] %>">
          <button class="btn btn-outline-secondary" type="submit" title="Найти">
            <i class="bi bi-search"></i>
          </button>
        </div>
      </div>

      <div class="col-lg-3">
        <label class="form-label">Дата поступления</label>
        <input type="date" name="admission_date" class="form-control"
               value="<%= params[:admission_date] || Date.today.to_s %>"
               required>
      </div>

      <div class="col-lg-3">
        <label class="form-label">Вид обращения</label>
        <select name="appeal_type" class="form-select">
          <option value="all">Все виды</option>
          <% Patient::APPEAL_TYPES.each do |type| %>
            <option value="<%= type %>" <%= 'selected' if params[:appeal_type] == type %>>
              <%= type %>
            </option>
          <% end %>
        </select>
      </div>

      <div class="col-lg-2">
        <label class="form-label">Статус триажа</label>
        <select name="only_active" class="form-select">
          <option value="">Все</option>
          <option value="1" <%= 'selected' if params[:only_active] == '1' %>>
            Только активные
          </option>
        </select>
      </div>

      <div class="col-lg-4">
        <label class="form-label">Исполнитель</label>
        <select name="performer_filter" class="form-select">
          <option value="">Все исполнители</option>
          <% @performers.each do |performer| %>
            <option value="<%= performer %>" <%= 'selected' if params[:performer_filter] == performer %>>
              <%= performer %>
            </option>
          <% end %>
        </select>
      </div>

      <div class="col-lg-4">
        <label class="form-label">Срок беременности</label>
        <select name="pregnancy_condition" class="form-select">
          <option value="">Все</option>
          <option value="unknown" <%= 'selected' if params[:pregnancy_condition] == 'unknown' %>>
            Неизвестно
          </option>
          <option value="less_12" <%= 'selected' if params[:pregnancy_condition] == 'less_12' %>>
            Менее 12 недель
          </option>
          <option value="12_28" <%= 'selected' if params[:pregnancy_condition] == '12_28' %>>
            12-28 недель
          </option>
          <option value="more_28" <%= 'selected' if params[:pregnancy_condition] == 'more_28' %>>
            Более 28 недель
          </option>
        </select>
      </div>

      <div class="col-lg-4">
        <label class="form-label" for="stat-patient-select">Пациент</label>
        <select name="patient_id" id="stat-patient-select" class="form-select" onchange="this.form.submit()">
          <option value="">— Выберите пациента —</option>
          <% @patients_for_select.each do |p| %>
            <option value="<%= p.id %>" <%= 'selected' if @selected_patient&.id == p.id %>>
              <%= p.full_name %> · ID <%= p.id %> · <%= p.admission_date&.strftime('%d.%m.%Y') %>
              <% unless @patients.any? { |x| x.id == p.id } %> (вне фильтра)<% end %>
            </option>
          <% end %>
        </select>
      </div>

      <div class="col-12 action-bar mt-2">
        <button type="submit" class="btn btn-primary">
          <i class="bi bi-funnel"></i> Применить и показать
        </button>
        <a href="/statistics" class="btn btn-outline-secondary">
          <i class="bi bi-x-lg"></i> Сбросить
        </a>
      </div>
    </form>
  </div>
</div>

<% if params[:patient_id].present? && @selected_patient.nil? %>
  <div class="alert alert-warning">Пациент не найден.</div>
<% elsif @selected_patient && @triage.nil? %>
  <div class="alert alert-warning">У выбранного пациента нет записи триажа.</div>
<% elsif @selected_patient && @triage %>

  <% t = @triage %>
  <div class="row g-3 mb-4">
    <div class="col-md-6 col-lg-4">
      <div class="app-card card h-100">
        <div class="app-card-header card-header py-2">
          <span class="text-muted small text-uppercase fw-normal">Пациент</span>
        </div>
        <div class="card-body small">
          <p class="mb-1"><strong>ФИО:</strong> <%= @selected_patient.full_name %></p>
          <p class="mb-1"><strong>Исполнитель:</strong> <%= @selected_patient.performer_name %></p>
          <p class="mb-1"><strong>Поступление:</strong> <%= @selected_patient.admission_date&.strftime('%d.%m.%Y') %> <%= @selected_patient.admission_time_formatted %></p>
          <p class="mb-0"><strong>Приоритет:</strong>
            <% if t.priority.present? && t.priority != 'pending' %>
              <span class="badge bg-secondary"><%= t.priority_name %></span>
            <% else %>
              <span class="text-muted">не определён</span>
            <% end %>
          </p>
        </div>
      </div>
    </div>
    <div class="col-md-6 col-lg-4">
      <div class="app-card card h-100">
        <div class="app-card-header card-header py-2">
          <span class="text-muted small text-uppercase fw-normal">Время триажа</span>
        </div>
        <div class="card-body small">
          <% total = t.statistics_total_triage_seconds %>
          <p class="mb-1"><strong>От создания триажа до завершения:</strong> <%= total ? "#{format_duration_sec(total)} (#{total} с)" : '—' %></p>
          <p class="mb-0"><strong>Триаж завершён:</strong> <%= t.completed_at ? format_nsk(t.completed_at) : '—' %></p>
        </div>
      </div>
    </div>
    <div class="col-md-12 col-lg-4">
      <div class="app-card card h-100">
        <div class="app-card-header card-header py-2">
          <span class="text-muted small text-uppercase fw-normal">Действия по приоритету (лимит <%= Triage::ACTIONS_TIME_LIMIT / 60 %> мин)</span>
        </div>
        <div class="card-body small">
          <% aph = t.statistics_actions_phase %>
          <% if aph %>
            <p class="mb-1"><strong>Фактически:</strong> <%= format_duration_sec(aph[:seconds_used]) %> (<%= aph[:seconds_used] %> с)</p>
            <p class="mb-1"><strong>Статус:</strong>
              <% if aph[:completed] && !aph[:within_limit].nil? %>
                <% if aph[:within_limit] %>
                  <span class="badge bg-success">в срок</span>
                <% else %>
                  <span class="badge bg-warning text-dark">превышен лимит</span>
                <% end %>
              <% elsif !aph[:completed] %>
                <span class="badge bg-info text-dark">в процессе</span>
              <% else %>
                —
              <% end %>
            </p>
            <p class="mb-0"><strong>Завершено:</strong> <%= t.actions_completed_at ? format_nsk(t.actions_completed_at) : '—' %></p>
          <% else %>
            <p class="mb-0 text-muted">Действия не начинались или триаж не завершён.</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="app-card card mb-4">
    <div class="app-card-header card-header">
      <span class="text-muted small text-uppercase fw-normal">Время по шагам триажа</span>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover mb-0 small">
          <thead class="table-light">
            <tr>
              <th>Шаг</th>
              <th>Название</th>
              <th>Лимит</th>
              <th>Факт</th>
              <th>Статус</th>
            </tr>
          </thead>
          <tbody>
            <% t.statistics_step_rows.each do |row| %>
              <tr>
                <td><%= row[:step] %></td>
                <td><%= row[:name] %></td>
                <td><%= format_duration_sec(row[:limit_seconds]) %> (<%= row[:limit_seconds] %> с)</td>
                <td><%= row[:seconds_used] ? "#{format_duration_sec(row[:seconds_used])} (#{row[:seconds_used]} с)" : '—' %></td>
                <td>
                  <% if row[:within_limit].nil? %>
                    <span class="text-muted">—</span>
                  <% elsif row[:within_limit] %>
                    <span class="badge bg-success">в срок</span>
                  <% else %>
                    <span class="badge bg-warning text-dark">превышен лимит</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="app-card card mb-4">
    <div class="app-card-header card-header d-flex align-items-center justify-content-between">
      <span class="text-muted small text-uppercase fw-normal">Журнал событий</span>
      <span class="badge bg-secondary" id="audit-total-badge"><%= @audit_events.size %></span>
    </div>
    <div class="card-body">
      <% if @audit_events.empty? %>
        <p class="text-muted mb-0">Событий пока нет (журнал ведётся с момента внедрения). Метрики по шагам выше рассчитываются по данным триажа, если они заполнены.</p>
      <% else %>
        <% events = @audit_events.to_a.sort_by(&:occurred_at) %>
        <% registration_events = events.select { |e| %w[patient_registered triage_started].include?(e.event_type.to_s) } %>
        <% step_submitted = {} %>
        <% (1..3).each do |n| %>
          <% step_submitted[n] = events.reverse.find { |e| e.event_type.to_s == "step#{n}_submitted" } %>
        <% end %>
        <% step_transitions = events.select { |e| %w[step_advanced priority_assigned].include?(e.event_type.to_s) } %>
        <% step_edits_by_step = Hash.new { |h, k| h[k] = [] } %>
        <% events.each do |e| %>
          <% if e.event_type.to_s == 'triage_edit_saved' %>
            <% sn = e.payload_hash['step'].to_i %>
            <% step_edits_by_step[sn] << e if sn.between?(1, 3) %>
          <% end %>
        <% end %>
        <% action_events = events.select { |e| %w[priority_action_marked priority_action_unmarked actions_completed].include?(e.event_type.to_s) } %>
        <% shown_blocks = 1 + step_submitted.values.compact.size + (action_events.any? ? 1 : 0) %>

        <div class="app-card card border-0 bg-light-subtle mb-3">
          <div class="card-body p-3">
            <div class="row g-2 align-items-end">
              <div class="col-lg-5">
                <label class="form-label small text-muted mb-1" for="audit-search-input">Поиск по блокам и полям</label>
                <input id="audit-search-input" type="search" class="form-control form-control-sm" placeholder="Шаг, исполнитель, параметр, значение...">
              </div>
              <div class="col-lg-7">
                <label class="form-label small text-muted mb-1 d-block">Фильтр блоков</label>
                <div class="audit-filter-buttons" id="audit-filter-buttons">
                  <button type="button" class="btn btn-sm btn-primary" data-audit-filter="all">Все блоки</button>
                  <button type="button" class="btn btn-sm btn-outline-secondary" data-audit-filter="registration">Регистрация</button>
                  <button type="button" class="btn btn-sm btn-outline-secondary" data-audit-filter="steps">Шаги</button>
                  <button type="button" class="btn btn-sm btn-outline-secondary" data-audit-filter="actions">Действия приоритета</button>
                </div>
              </div>
            </div>
            <div class="small text-muted mt-2">
              Показано блоков: <span id="audit-visible-count"><%= shown_blocks %></span> из <%= shown_blocks %>
            </div>
          </div>
        </div>

        <div id="audit-blocks-container" class="d-flex flex-column gap-3">
          <section class="audit-block" data-audit-group="registration">
            <div class="audit-block-head">
              <span class="badge audit-type-badge audit-type-secondary"><i class="bi bi-person-plus me-1"></i>Регистрация пациента</span>
            </div>
            <div class="audit-block-body">
              <% if registration_events.any? %>
                <ul class="list-unstyled mb-0 audit-line-list">
                  <% registration_events.each do |ev| %>
                    <% ph = ev.payload_hash %>
                    <li class="audit-line-item">
                      <span class="audit-line-time"><%= format_nsk(ev.occurred_at) %></span>
                      <span class="audit-line-label"><%= audit_event_label(ev.event_type) %></span>
                      <span class="audit-line-meta">исполнитель: <strong><%= Rack::Utils.escape_html((ph['performer_name'] || '—').to_s) %></strong></span>
                    </li>
                  <% end %>
                </ul>
              <% else %>
                <div class="text-muted small">События регистрации не найдены.</div>
              <% end %>
            </div>
          </section>

          <% (1..3).each do |n| %>
            <% ev = step_submitted[n] %>
            <% next unless ev %>
            <% ph = ev.payload_hash %>
            <%
              timing_badge_class, timing_badge_text = if ph['within_limit'].nil?
                                                        ['bg-secondary-subtle text-secondary-emphasis border', 'нет данных']
                                                      elsif ph['within_limit']
                                                        ['bg-success-subtle text-success-emphasis border border-success-subtle', 'в лимите']
                                                      else
                                                        ['bg-warning-subtle text-warning-emphasis border border-warning-subtle', 'лимит превышен']
                                                      end
            %>
            <section class="audit-block" data-audit-group="steps">
              <div class="audit-block-head">
                <span class="badge audit-type-badge audit-type-warning"><i class="bi bi-signpost-split me-1"></i>Шаг <%= n %></span>
                <span class="audit-line-time ms-2"><%= format_nsk(ev.occurred_at) %></span>
              </div>
              <div class="audit-block-body">
                <div class="audit-chip-grid mb-2">
                  <span class="audit-chip"><span>Исполнитель</span><strong><%= Rack::Utils.escape_html((ph['performer_name'] || '—').to_s) %></strong></span>
                  <span class="audit-chip"><span>Приоритет</span><strong><%= Rack::Utils.escape_html(Triage.priority_label_ru(ph['priority'])) %></strong></span>
                  <span class="audit-chip"><span>Лимит</span><strong><%= ph['limit_seconds'] ? "#{format_duration_sec(ph['limit_seconds'])} (#{ph['limit_seconds']} с)" : '—' %></strong></span>
                  <span class="audit-chip"><span>Затрачено</span><strong><%= ph['seconds_used'] ? "#{format_duration_sec(ph['seconds_used'])} (#{ph['seconds_used']} с)" : '—' %></strong></span>
                  <span class="audit-chip"><span>Таймер шага</span><strong><%= ph['timer_expired'] ? 'истёк' : 'не истёк' %></strong></span>
                  <span class="audit-chip"><span>Лимит шага</span><strong><span class="badge <%= timing_badge_class %>"><%= timing_badge_text %></span></strong></span>
                </div>

                <% captured_at = ph['step_values_captured_at'] %>
                <div class="small text-muted mb-2">
                  <i class="bi bi-clock-history me-1"></i>Время фиксации полей шага: <strong><%= captured_at ? format_nsk(Time.at(captured_at.to_i)) : format_nsk(ev.occurred_at) %></strong>
                </div>

                <% rows = step_values_rows_from_payload(ph) %>
                <% if rows.any? %>
                  <div class="audit-compact-table mb-2">
                    <% rows.each do |label, value| %>
                      <div class="audit-row">
                        <div class="audit-k"><%= Rack::Utils.escape_html(label) %></div>
                        <div class="audit-v"><%= Rack::Utils.escape_html(value) %></div>
                      </div>
                    <% end %>
                  </div>
                <% end %>

                <% related_step_events = step_transitions.select { |x| xh = x.payload_hash; (xh['step'].to_i == n) || (xh['from_step'].to_i == n) } %>
                <% if related_step_events.any? %>
                  <div class="small mb-2">
                    <% related_step_events.each do |se| %>
                      <div class="audit-inline-event">
                        <span class="audit-line-time"><%= format_nsk(se.occurred_at) %></span>
                        <span><%= audit_event_label(se.event_type) %></span>
                      </div>
                    <% end %>
                  </div>
                <% end %>

                <% edits = step_edits_by_step[n] %>
                <% if edits.any? %>
                  <div class="audit-edit-box mt-2">
                    <div class="small fw-semibold mb-2"><i class="bi bi-pencil-square me-1"></i>Редактирования шага</div>
                    <% edits.each do |ed| %>
                      <% eph = ed.payload_hash %>
                      <div class="audit-edit-item">
                        <div class="small mb-1">
                          <span class="audit-line-time"><%= format_nsk(ed.occurred_at) %></span>
                          <span class="ms-2">исполнитель: <strong><%= Rack::Utils.escape_html((eph['performer_name'] || '—').to_s) %></strong></span>
                        </div>
                        <% ch = step_changed_rows_from_payload(eph) %>
                        <% if ch.any? %>
                          <div class="audit-compact-table">
                            <% ch.each do |label, before_v, after_v| %>
                              <div class="audit-row audit-row-changed">
                                <div class="audit-k"><%= Rack::Utils.escape_html(label) %></div>
                                <div class="audit-v">
                                  <span class="audit-before"><%= Rack::Utils.escape_html(before_v) %></span>
                                  <i class="bi bi-arrow-right mx-1 text-muted"></i>
                                  <span class="audit-after"><%= Rack::Utils.escape_html(after_v) %></span>
                                </div>
                              </div>
                            <% end %>
                          </div>
                        <% else %>
                          <div class="small text-muted">Изменённые поля не зафиксированы.</div>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </section>
          <% end %>

          <% if action_events.any? %>
            <section class="audit-block" data-audit-group="actions">
              <div class="audit-block-head">
                <span class="badge audit-type-badge audit-type-info"><i class="bi bi-list-check me-1"></i>Действия приоритета</span>
              </div>
              <div class="audit-block-body">
                <ul class="list-unstyled mb-0 audit-line-list">
                  <% action_events.each do |ev| %>
                    <% ph = ev.payload_hash %>
                    <li class="audit-line-item">
                      <span class="audit-line-time"><%= format_nsk(ev.occurred_at) %></span>
                      <span class="audit-line-label"><%= audit_event_label(ev.event_type) %></span>
                      <% if ph['action'].present? %>
                        <span class="audit-line-meta"><%= Rack::Utils.escape_html(Triage.action_text_for_key(ph['action'])) %></span>
                      <% end %>
                      <% if ph['value'].present? %>
                        <span class="badge bg-light border text-dark"><%= Rack::Utils.escape_html(ph['value'].to_s) %></span>
                      <% end %>
                      <span class="audit-line-meta">исполнитель: <strong><%= Rack::Utils.escape_html((ph['performer_name'] || '—').to_s) %></strong></span>
                    </li>
                  <% end %>
                </ul>
              </div>
            </section>
          <% end %>
        </div>

        <div id="audit-empty-filtered" class="alert alert-light border mt-3 d-none mb-0">
          <i class="bi bi-funnel"></i> По выбранным фильтрам блоков ничего не найдено.
        </div>
        <script>
          (function() {
            var buttonsWrap = document.getElementById('audit-filter-buttons');
            var searchInput = document.getElementById('audit-search-input');
            var blocks = Array.prototype.slice.call(document.querySelectorAll('.audit-block[data-audit-group]'));
            var visibleCountEl = document.getElementById('audit-visible-count');
            var emptyEl = document.getElementById('audit-empty-filtered');
            if (!buttonsWrap || !searchInput || blocks.length === 0) return;

            var activeGroup = 'all';

            function normalize(s) {
              return (s || '').toString().toLowerCase().trim();
            }

            function applyFilters() {
              var q = normalize(searchInput.value);
              var shown = 0;
              blocks.forEach(function(block) {
                var group = block.getAttribute('data-audit-group');
                var groupOk = activeGroup === 'all' || group === activeGroup || (activeGroup === 'steps' && group === 'steps');
                var textOk = q === '' || normalize(block.textContent).indexOf(q) !== -1;
                var show = groupOk && textOk;
                block.classList.toggle('d-none', !show);
                if (show) shown += 1;
              });

              if (visibleCountEl) visibleCountEl.textContent = shown;
              if (emptyEl) emptyEl.classList.toggle('d-none', shown > 0);
            }

            buttonsWrap.querySelectorAll('button[data-audit-filter]').forEach(function(btn) {
              btn.addEventListener('click', function() {
                activeGroup = this.getAttribute('data-audit-filter') || 'all';
                buttonsWrap.querySelectorAll('button[data-audit-filter]').forEach(function(b) {
                  b.classList.remove('btn-primary');
                  b.classList.add('btn-outline-secondary');
                });
                this.classList.remove('btn-outline-secondary');
                this.classList.add('btn-primary');
                applyFilters();
              });
            });

            searchInput.addEventListener('input', applyFilters);
          })();
        </script>
      <% end %>
    </div>
  </div>

<% end %>
