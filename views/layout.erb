<!DOCTYPE html>
<html lang="ru">
<head>
  <%= erb :head_common, locals: { page_title: (@page_title || 'Триаж — Госпитальная система') } %>
</head>
<body>
  <header class="app-header">
    <div class="container-fluid app-header-bar px-3 px-lg-4">
      <div class="d-flex align-items-center justify-content-between w-100 gap-2">
        <div class="d-flex align-items-center gap-2 flex-shrink-0">
          <button class="app-nav-toggle-btn d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#appNavOffcanvas" aria-controls="appNavOffcanvas" aria-label="Открыть меню">
            <i class="bi bi-list" aria-hidden="true"></i>
          </button>
          <a href="/patients" class="app-logo" title="На главную — список пациентов">
            <img src="/images/logo.png" alt="" class="app-logo-img" width="40" height="40" decoding="async">
            <span class="app-logo-text">Триаж</span>
          </a>
        </div>

        <nav class="d-none d-lg-flex align-items-center justify-content-center flex-grow-1 gap-2 flex-wrap mx-2" aria-label="Основное меню">
          <a href="/patients" class="app-nav-btn text-nowrap"><i class="bi bi-people" aria-hidden="true"></i> Пациенты</a>
          <a href="/statistics" class="app-nav-btn text-nowrap"><i class="bi bi-graph-up-arrow" aria-hidden="true"></i> Статистика</a>
          <% if current_user&.admin? %>
            <div class="dropdown">
              <button class="app-nav-btn dropdown-toggle border-0" type="button" id="appAdminDropdown" data-bs-toggle="dropdown" aria-expanded="false" data-bs-display="static">
                <i class="bi bi-gear" aria-hidden="true"></i> Администрирование
              </button>
              <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="appAdminDropdown">
                <li><a class="dropdown-item" href="/admin/users"><i class="bi bi-people me-2"></i>Пользователи</a></li>
                <li><a class="dropdown-item" href="/admin/positions"><i class="bi bi-card-list me-2"></i>Должности</a></li>
              </ul>
            </div>
          <% end %>
        </nav>

        <div class="d-none d-lg-flex align-items-center gap-2 flex-shrink-0">
          <% if current_user %>
            <span class="text-white small" style="opacity: 0.95; max-width: 12rem;" title="<%= Rack::Utils.escape_html(current_user.full_name) %>"><%= Rack::Utils.escape_html(current_user.full_name) %></span>
            <form method="post" action="/logout" class="d-inline m-0">
              <button type="submit" class="app-nav-btn btn btn-link p-0 border-0 text-decoration-none"><i class="bi bi-box-arrow-right" aria-hidden="true"></i> Выход</button>
            </form>
          <% end %>
          <a href="/monitor" target="_blank" rel="noopener noreferrer" class="app-nav-btn text-nowrap"><i class="bi bi-tv" aria-hidden="true"></i> Монитор ТВ</a>
        </div>
      </div>
    </div>

    <div class="offcanvas offcanvas-start app-offcanvas text-bg-light" tabindex="-1" id="appNavOffcanvas" aria-labelledby="appNavOffcanvasLabel">
      <div class="offcanvas-header align-items-center border-bottom">
        <div class="d-flex align-items-center gap-3 flex-grow-1 min-w-0">
          <img src="/images/logo.png" alt="" class="app-logo-img app-logo-img--drawer" width="44" height="44" decoding="async">
          <div class="min-w-0">
            <h5 class="offcanvas-title fw-bold mb-0 text-dark" id="appNavOffcanvasLabel">Меню</h5>
            <div class="small text-muted text-truncate">Триаж</div>
          </div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Закрыть"></button>
      </div>
      <div class="offcanvas-body d-flex flex-column">
        <nav class="d-flex flex-column gap-1 flex-grow-1" aria-label="Мобильное меню">
          <a class="app-mobile-nav-link" href="/patients" data-bs-dismiss="offcanvas"><i class="bi bi-people" aria-hidden="true"></i> Пациенты</a>
          <a class="app-mobile-nav-link" href="/statistics" data-bs-dismiss="offcanvas"><i class="bi bi-graph-up-arrow" aria-hidden="true"></i> Статистика</a>
          <% if current_user&.admin? %>
            <div class="app-mobile-nav-divider"></div>
            <span class="small text-muted text-uppercase px-2 mb-1">Администрирование</span>
            <a class="app-mobile-nav-link" href="/admin/users" data-bs-dismiss="offcanvas"><i class="bi bi-people" aria-hidden="true"></i> Пользователи</a>
            <a class="app-mobile-nav-link" href="/admin/positions" data-bs-dismiss="offcanvas"><i class="bi bi-card-list" aria-hidden="true"></i> Должности</a>
          <% end %>
          <div class="app-mobile-nav-divider"></div>
          <a class="app-mobile-nav-link" href="/monitor" target="_blank" rel="noopener noreferrer" data-bs-dismiss="offcanvas"><i class="bi bi-tv" aria-hidden="true"></i> Монитор ТВ</a>
        </nav>
        <% if current_user %>
          <div class="mt-auto pt-3 border-top border-light">
            <p class="small text-muted mb-2 px-2 text-truncate" title="<%= Rack::Utils.escape_html(current_user.full_name) %>"><%= Rack::Utils.escape_html(current_user.full_name) %></p>
            <form method="post" action="/logout" class="d-grid">
              <button type="submit" class="btn btn-outline-secondary" data-bs-dismiss="offcanvas"><i class="bi bi-box-arrow-right me-1"></i>Выход</button>
            </form>
          </div>
        <% end %>
      </div>
    </div>
  </header>

  <main class="app-container container">
    <% if flash[:notice] %>
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        <%= flash[:notice] %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрыть"></button>
      </div>
    <% end %>
    <% if flash[:error] %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <%= flash[:error] %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрыть"></button>
      </div>
    <% end %>
    <% if flash[:info] %>
      <div class="alert alert-info alert-dismissible fade show" role="alert">
        <%= flash[:info] %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Закрыть"></button>
      </div>
    <% end %>

    <%= yield %>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <% if @patients_list_js %>
  <script src="/js/patients_list.js"></script>
  <% end %>
  <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
  <script>
    $(document).ready(function() {
      $('form[method="post"]').each(function() {
        const method = $(this).find('input[name="_method"]').val();
        if (method) {
          $(this).attr('method', 'post');
        }
      });
    });
  </script>
  <script>
    (function() {
      if (!('serviceWorker' in navigator)) return;
      var loc = window.location;
      if (loc.protocol !== 'https:' && loc.hostname !== 'localhost' && loc.hostname !== '127.0.0.1') return;
      navigator.serviceWorker.register('/sw.js').catch(function () {});
    })();
  </script>
  <% if @triage_edit_with_save_guard %>
  <%= erb :triage_edit_save_guard, layout: false %>
  <% end %>
</body>
</html>
