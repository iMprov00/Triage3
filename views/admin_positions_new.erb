<div class="mb-4">
  <h1 class="page-title">Новая должность</h1>
  <p class="text-muted small mb-0">Название видят пользователи; тип задаёт права в системе.</p>
</div>

<div class="app-card card" style="max-width: 560px;">
  <div class="card-body">
    <% if flash[:error] %>
      <div class="alert alert-danger"><%= flash[:error] %></div>
    <% end %>
    <form method="post" action="/admin/positions" class="row g-3">
      <div class="col-12">
        <label class="form-label">Название</label>
        <input type="text" name="name" class="form-control" required maxlength="120"
               placeholder="Например: Заведующий отделением" value="<%= Rack::Utils.escape_html(@position.name.to_s) %>">
      </div>
      <div class="col-12">
        <label class="form-label">Тип (права)</label>
        <select name="kind" class="form-select" required>
          <% JobPosition::KINDS.each do |k| %>
            <option value="<%= k %>"><%= Rack::Utils.escape_html(JobPosition::KIND_LABELS[k]) %></option>
          <% end %>
        </select>
      </div>
      <div class="col-12 action-bar">
        <button type="submit" class="btn btn-primary">Добавить</button>
        <a href="/admin/positions" class="btn btn-outline-secondary">Отмена</a>
      </div>
    </form>
  </div>
</div>
