<%# Красный приоритет: нет дыхания / нет сердцебиения — двухколоночный сценарий %>
<% priority_config = { color: 'danger', title: 'СРОЧНЫЕ МЕРЫ (остановка сердца)', icon: 'exclamation-triangle-fill', bg: 'bg-danger' } %>
<% ra = @triage.red_arrest_data %>
<% timer_action = @triage.timer_action %>
<% brigade_ok = @triage.brigade_called_at.present? %>

<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
  <div>
    <h1 class="page-title mb-1 text-<%= priority_config[:color] %>">
      <i class="bi bi-<%= priority_config[:icon] %>"></i> <%= priority_config[:title] %>
    </h1>
    <p class="text-muted mb-0">
      <%= @patient.full_name %> · Приоритет:
      <span class="badge <%= priority_config[:bg] %>"><%= @triage.priority_name %></span>
      <span class="text-muted small ms-2">Нет дыхания и/или нет сердцебиения на шаге 1</span>
    </p>
  </div>
</div>

<div class="row mb-3">
  <div class="col-12">
    <%= erb :step_performer_field, locals: { step_key: 'actions' } %>
  </div>
</div>

<div class="row mb-3">
  <div class="col-lg-6 mb-3">
    <div class="app-card card h-100">
      <div class="app-card-header card-header">
        <span class="text-muted small text-uppercase fw-normal">Время на действия</span>
      </div>
      <div class="card-body">
        <div class="timer-box <%= @triage.actions_time_expired? ? 'timer-expired' : 'timer-running' %>"
             id="actions-timer"
             data-timer-ends-at="<%= @triage.actions_timer_ends_at || 0 %>"
             data-max-time="<%= Triage::ACTIONS_TIME_LIMIT %>">
          <div class="text-center">
            <div class="timer-value display-4 fw-bold" id="actions-timer-display">
              <%= @triage.actions_time_remaining %> сек
            </div>
            <small class="text-muted">из 5 минут</small>
          </div>
          <div class="progress mt-3">
            <% percent = (@triage.actions_time_remaining.to_f / Triage::ACTIONS_TIME_LIMIT * 100).to_i %>
            <div class="progress-bar <%= percent <= 25 ? 'progress-bar-danger' : (percent <= 50 ? 'progress-bar-warning' : 'progress-bar-success') %>"
                 id="actions-progress-bar"
                 style="width: <%= [percent, 100].min %>%"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-lg-6 mb-3">
    <div class="app-card card h-100 <%= brigade_ok ? '' : 'd-none' %>" id="brigade-timer-card">
      <div class="app-card-header card-header <%= priority_config[:bg] %>">
        <span class="small text-uppercase fw-normal text-white">
          <i class="bi bi-truck"></i> <%= @triage.brigade_timer_label %>
        </span>
      </div>
      <div class="card-body">
        <div class="timer-box timer-running"
             id="brigade-timer"
             data-timer-ends-at="<%= @triage.brigade_timer_ends_at || 0 %>"
             data-max-time="<%= @triage.brigade_time_limit %>">
          <div class="text-center">
            <div class="timer-value display-5 fw-bold" id="brigade-timer-display">
              <%= @triage.brigade_time_remaining || 0 %> сек
            </div>
            <small class="text-muted">из <%= timer_action ? timer_action[:timer_minutes] : 12 %> минут</small>
          </div>
          <div class="progress mt-3">
            <% brigade_percent = @triage.brigade_time_remaining ? (@triage.brigade_time_remaining.to_f / @triage.brigade_time_limit * 100).to_i : 100 %>
            <div class="progress-bar progress-bar-warning"
                 id="brigade-progress-bar"
                 style="width: <%= [brigade_percent, 100].min %>%"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-3">
  <%# Слева — вызов бригады %>
  <div class="col-lg-6">
    <div class="app-card card h-100">
      <div class="app-card-header card-header bg-danger text-white">
        <span class="small text-uppercase fw-normal"><i class="bi bi-telephone-fill"></i> Вызов бригады оказания помощи</span>
      </div>
      <div class="card-body">
        <% unless brigade_ok %>
          <button type="button" class="btn btn-danger btn-lg w-100 mb-4" id="ra-btn-brigade" <%= 'disabled' if @triage.actions_completed? %>>
            Бригада вызвана
          </button>
        <% else %>
          <div class="alert alert-success py-2 mb-4">
            <i class="bi bi-check-circle-fill"></i> Бригада вызвана — <%= format_nsk(@triage.brigade_called_at) %>
          </div>
        <% end %>

        <div id="ra-team-block" class="<%= brigade_ok ? '' : 'd-none' %>">
          <p class="small text-muted mb-2">Специалисты (отметка и время фиксируются в журнале)</p>
          <% Triage::RED_ARREST_TEAM.each do |item| %>
            <% k = item[:key] %>
            <% ts = ra.dig('team', k) %>
            <% done = ts.present? %>
            <div class="form-check mb-2 red-arrest-item <%= done ? 'bg-success-subtle border border-success rounded px-2 py-2' : '' %>"
                 data-group="team" data-key="<%= k %>">
              <input class="form-check-input ra-toggle" type="checkbox" id="ra_team_<%= k %>"
                     data-group="team" data-key="<%= k %>"
                     <%= 'checked' if done %>
                     <%= 'disabled' if @triage.actions_completed? || !brigade_ok %>>
              <label class="form-check-label" for="ra_team_<%= k %>"><%= item[:label] %></label>
              <% if ts %>
                <div class="small text-muted ms-4"><%= format_nsk(Time.at(ts.to_i)) %></div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# Справа — манипуляции %>
  <div class="col-lg-6">
    <div class="app-card card h-100">
      <div class="app-card-header card-header bg-danger text-white">
        <span class="small text-uppercase fw-normal"><i class="bi bi-tools"></i> Манипуляции</span>
      </div>
      <div class="card-body">
        <% Triage::RED_ARREST_MANIPS.each do |item| %>
          <% k = item[:key] %>
          <% ts = ra.dig('manip', k) %>
          <% done = ts.present? %>
          <div class="form-check mb-2 red-arrest-item <%= done ? 'bg-success-subtle border border-success rounded px-2 py-2' : '' %>"
               data-group="manip" data-key="<%= k %>">
            <input class="form-check-input ra-toggle" type="checkbox" id="ra_manip_<%= k %>"
                   data-group="manip" data-key="<%= k %>"
                   <%= 'checked' if done %>
                   <%= 'disabled' if @triage.actions_completed? %>>
            <label class="form-check-label" for="ra_manip_<%= k %>"><%= item[:label] %></label>
            <% if ts %>
              <div class="small text-muted ms-4"><%= format_nsk(Time.at(ts.to_i)) %></div>
            <% end %>
          </div>

          <% if k == 'oxygen_inhalation' %>
            <hr class="my-3">
            <p class="small text-muted text-uppercase mb-2">Показатели (3 последовательных замера)</p>
            <% Triage::RED_ARREST_VITALS.each do |v| %>
              <% vk = v[:key] %>
              <% vd = ra.dig('vitals', vk) %>
              <% values = if vd.is_a?(Hash) && vd['values'].is_a?(Array)
                            vd['values']
                          elsif vd.is_a?(Hash) && vd['value'].present?
                            [vd['value'].to_s, '', '']
                          else
                            ['', '', '']
                          end %>
              <% vat = vd.is_a?(Hash) ? vd['at'] : nil %>
              <div class="mb-2">
                <label class="form-label mb-1"><%= v[:label] %></label>
                <div class="d-flex gap-1 flex-nowrap">
                  <% 3.times do |idx| %>
                    <% key_idx = "#{vk}_#{idx + 1}" %>
                    <% val_idx = values[idx].to_s %>
                    <% prev_filled = idx.zero? || values[idx - 1].to_s.strip.present? %>
                    <input type="text"
                           class="form-control form-control-sm ra-vital ra-vital-compact"
                           id="ra_vital_<%= key_idx %>"
                           data-key="<%= key_idx %>"
                           data-last-sent="<%= Rack::Utils.escape_html(val_idx) %>"
                           value="<%= Rack::Utils.escape_html(val_idx) %>"
                           placeholder="<%= idx + 1 %>"
                           <%= 'disabled' if @triage.actions_completed? || !prev_filled %>>
                  <% end %>
                </div>
                <% if vat %>
                  <div class="small text-muted mt-1">Последний ввод: <%= format_nsk(Time.at(vat.to_i)) %></div>
                <% end %>
              </div>
            <% end %>

            <hr class="my-3">
            <% fetal_val = ra.dig('vitals', 'fetal_heartbeat').to_s %>
            <% fetal_val = 'yes' if fetal_val.blank? %>
            <% bleeding_val = ra.dig('vitals', 'active_bleeding').to_s %>
            <% bleeding_val = 'no' if bleeding_val.blank? %>
            <div class="mb-2">
              <div class="small fw-semibold mb-1">Сердцебиение плода выслушивается</div>
              <div class="btn-group btn-group-sm" role="group" aria-label="Сердцебиение плода">
                <input type="radio" class="btn-check ra-vital-choice" name="ra_fetal_heartbeat" id="ra_fetal_heartbeat_yes" data-key="fetal_heartbeat" value="yes" <%= 'checked' if fetal_val == 'yes' %> <%= 'disabled' if @triage.actions_completed? %>>
                <label class="btn btn-outline-secondary" for="ra_fetal_heartbeat_yes">Да</label>
                <input type="radio" class="btn-check ra-vital-choice" name="ra_fetal_heartbeat" id="ra_fetal_heartbeat_no" data-key="fetal_heartbeat" value="no" <%= 'checked' if fetal_val == 'no' %> <%= 'disabled' if @triage.actions_completed? %>>
                <label class="btn btn-outline-secondary" for="ra_fetal_heartbeat_no">Нет</label>
              </div>
            </div>
            <div class="mb-3">
              <div class="small fw-semibold mb-1">Наличие кровотечения</div>
              <div class="btn-group btn-group-sm" role="group" aria-label="Наличие кровотечения">
                <input type="radio" class="btn-check ra-vital-choice" name="ra_active_bleeding" id="ra_active_bleeding_yes" data-key="active_bleeding" value="yes" <%= 'checked' if bleeding_val == 'yes' %> <%= 'disabled' if @triage.actions_completed? %>>
                <label class="btn btn-outline-secondary" for="ra_active_bleeding_yes">Да</label>
                <input type="radio" class="btn-check ra-vital-choice" name="ra_active_bleeding" id="ra_active_bleeding_no" data-key="active_bleeding" value="no" <%= 'checked' if bleeding_val == 'no' %> <%= 'disabled' if @triage.actions_completed? %>>
                <label class="btn btn-outline-secondary" for="ra_active_bleeding_no">Нет</label>
              </div>
            </div>
          <% end %>

          <% if k == 'vein_catheter' %>
            <div class="mb-3 mt-2">
              <div class="small fw-semibold mb-2">Введение адреналина 0,1% - 1,0 мл в/в</div>
              <div class="d-flex gap-2 flex-wrap">
                <% 3.times do |i| %>
                  <% a_key = "adrenaline_#{i + 1}" %>
                  <% a_done = ra.dig('manip', a_key).present? %>
                  <% prev_ok = i.zero? || ra.dig('manip', "adrenaline_#{i}").present? %>
                  <div class="form-check red-arrest-item <%= a_done ? 'bg-success-subtle border border-success rounded px-2 py-1' : '' %>">
                    <input class="form-check-input ra-toggle" type="checkbox" id="ra_manip_<%= a_key %>" data-group="manip" data-key="<%= a_key %>" <%= 'checked' if a_done %> <%= 'disabled' if @triage.actions_completed? || !prev_ok %>>
                    <label class="form-check-label small" for="ra_manip_<%= a_key %>"><%= i + 1 %></label>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        <% end %>

        <hr class="my-3">
        <% ts = ra.dig('manip', 'csection_done') || ra.dig('manip', 'urgent_cesarean') %>
        <% done = ts.present? %>
        <div class="form-check mb-3 red-arrest-item <%= done ? 'bg-success-subtle border border-success rounded px-2 py-2' : '' %>"
             data-group="manip" data-key="csection_done">
          <input class="form-check-input ra-toggle" type="checkbox" id="ra_manip_csection_done"
                 data-group="manip" data-key="csection_done"
                 <%= 'checked' if done %>
                 <%= 'disabled' if @triage.actions_completed? %>>
          <label class="form-check-label fw-semibold" for="ra_manip_csection_done">Выполнено кесарево сечение</label>
          <% if ts %>
            <div class="small text-muted ms-4"><%= format_nsk(Time.at(ts.to_i)) %></div>
          <% end %>
        </div>

        <% rec_ts = ra.dig('manip', 'resusc_outcome_recovery') || ra.dig('manip', 'slr_complete') %>
        <% death_ts = ra.dig('manip', 'resusc_outcome_death') %>
        <div class="mb-2">
          <div class="small fw-semibold mb-1">Исход СЛР (выбрать один)</div>
          <div class="d-grid gap-2">
            <div class="form-check red-arrest-item <%= rec_ts ? 'bg-success-subtle border border-success rounded px-2 py-2' : '' %>">
              <input class="form-check-input ra-outcome" type="radio" name="ra_resusc_outcome" id="ra_outcome_recovery"
                     data-key="resusc_outcome_recovery" value="recovery"
                     <%= 'checked' if rec_ts %>
                     <%= 'disabled' if @triage.actions_completed? %>>
              <label class="form-check-label" for="ra_outcome_recovery">Восстановление сердечной деятельности. Завершение СЛР</label>
            </div>
            <div class="form-check red-arrest-item <%= death_ts ? 'bg-success-subtle border border-success rounded px-2 py-2' : '' %>">
              <input class="form-check-input ra-outcome" type="radio" name="ra_resusc_outcome" id="ra_outcome_death"
                     data-key="resusc_outcome_death" value="death"
                     <%= 'checked' if death_ts %>
                     <%= 'disabled' if @triage.actions_completed? %>>
              <label class="form-check-label" for="ra_outcome_death">Смерть</label>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row mt-4">
  <div class="col-12">
    <div class="action-bar justify-content-center flex-wrap gap-2">
      <button type="button" class="btn btn-success btn-lg" id="ra-complete-btn"
              <%= 'disabled' unless @triage.can_complete_red_arrest? %>
              <%= 'disabled' if @triage.actions_completed? %>>
        <i class="bi bi-check-circle"></i> Завершить действия
      </button>
      <a href="/patients" class="btn btn-outline-secondary btn-lg">К списку пациентов</a>
    </div>
    <% unless @triage.can_complete_red_arrest? %>
      <p class="text-center text-muted small mt-2 mb-0">
        Чтобы завершить: нажмите «Бригада вызвана», затем отметьте «Выполнено кесарево сечение» и/или один из исходов СЛР.
      </p>
    <% end %>
  </div>
</div>

<script>
(function() {
  var patientId = <%= @patient.id %>;
  var brigadeCalled = <%= brigade_ok ? 'true' : 'false' %>;

  function actionsPerformerParam() {
    var el = document.querySelector('select[name="step_performer_user_id"], input[name="step_performer_user_id"]');
    if (!el) return '';
    return 'step_performer_user_id=' + encodeURIComponent(el.value);
  }

  function formatTimerValue(seconds) {
    var mins = Math.floor(seconds / 60);
    var secs = seconds % 60;
    return mins + ':' + secs.toString().padStart(2, '0');
  }

  function updateTimers() {
    var now = Date.now() / 1000;
    var actionsTimer = document.getElementById('actions-timer');
    if (actionsTimer) {
      var endsAt = parseFloat(actionsTimer.dataset.timerEndsAt) || 0;
      var maxTime = parseFloat(actionsTimer.dataset.maxTime) || 300;
      if (endsAt > 0) {
        var remaining = Math.max(0, Math.floor(endsAt - now));
        var percent = Math.round((remaining / maxTime) * 100);
        var el = document.getElementById('actions-timer-display');
        if (el) el.textContent = formatTimerValue(remaining);
        var progressBar = document.getElementById('actions-progress-bar');
        if (progressBar) {
          progressBar.style.width = percent + '%';
          progressBar.className = 'progress-bar ' + (percent <= 25 ? 'progress-bar-danger' : (percent <= 50 ? 'progress-bar-warning' : 'progress-bar-success'));
        }
        actionsTimer.classList.remove('timer-running', 'timer-expired');
        actionsTimer.classList.add(remaining <= 0 ? 'timer-expired' : 'timer-running');
      }
    }
    var brigadeTimer = document.getElementById('brigade-timer');
    if (brigadeTimer && brigadeTimer.dataset.timerEndsAt && parseFloat(brigadeTimer.dataset.timerEndsAt) > 0) {
      var endsAt2 = parseFloat(brigadeTimer.dataset.timerEndsAt) || 0;
      var maxTime2 = parseFloat(brigadeTimer.dataset.maxTime) || 720;
      var remaining2 = Math.max(0, Math.floor(endsAt2 - now));
      var percent2 = Math.round((remaining2 / maxTime2) * 100);
      var el2 = document.getElementById('brigade-timer-display');
      if (el2) el2.textContent = formatTimerValue(remaining2);
      var pb = document.getElementById('brigade-progress-bar');
      if (pb) pb.style.width = percent2 + '%';
    }
  }

  function postForm(url, body, onOk) {
    var xhr = new XMLHttpRequest();
    xhr.open('POST', url, true);
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    xhr.onload = function() {
      if (xhr.status === 200) {
        try {
          var response = JSON.parse(xhr.responseText);
          if (response.error) return;
          if (onOk) onOk(response);
        } catch (e) {}
      }
    };
    var ap = actionsPerformerParam();
    if (ap) body = body ? (body + '&' + ap) : ap;
    xhr.send(body || '');
  }

  function setCompleteEnabled(canComplete) {
    var btn = document.getElementById('ra-complete-btn');
    if (!btn) return;
    btn.disabled = !canComplete;
  }

  function computeCanCompleteLocally() {
    if (!brigadeCalled) return false;
    var csection = document.getElementById('ra_manip_csection_done');
    var outcomeRecovery = document.getElementById('ra_outcome_recovery');
    var outcomeDeath = document.getElementById('ra_outcome_death');
    var hasCsection = !!(csection && csection.checked);
    var hasOutcome = !!((outcomeRecovery && outcomeRecovery.checked) || (outcomeDeath && outcomeDeath.checked));
    return hasCsection || hasOutcome;
  }

  function refreshCompleteState(serverCanComplete) {
    if (typeof serverCanComplete === 'boolean') {
      setCompleteEnabled(serverCanComplete || computeCanCompleteLocally());
      return;
    }
    setCompleteEnabled(computeCanCompleteLocally());
  }

  function refreshSequentialVitals() {
    ['bp', 'pulse', 'saturation'].forEach(function(base) {
      var i1 = document.getElementById('ra_vital_' + base + '_1');
      var i2 = document.getElementById('ra_vital_' + base + '_2');
      var i3 = document.getElementById('ra_vital_' + base + '_3');
      if (!i1 || !i2 || !i3) return;
      if (i1.disabled) return;
      i2.disabled = i1.value.trim() === '';
      i3.disabled = i2.disabled || i2.value.trim() === '';
      if (i2.disabled) i2.value = '';
      if (i3.disabled) i3.value = '';
    });
  }

  function refreshSequentialAdrenaline() {
    var a1 = document.getElementById('ra_manip_adrenaline_1');
    var a2 = document.getElementById('ra_manip_adrenaline_2');
    var a3 = document.getElementById('ra_manip_adrenaline_3');
    if (!a1 || !a2 || !a3) return;
    if (a1.disabled && a2.disabled && a3.disabled) return;
    a2.disabled = !a1.checked;
    a3.disabled = !a2.checked;
    if (!a2.checked) a3.checked = false;
  }

  function paintToggleState(inputEl) {
    var wrap = inputEl.closest('.red-arrest-item');
    if (!wrap) return;
    wrap.classList.toggle('bg-success-subtle', !!inputEl.checked);
    wrap.classList.toggle('border', !!inputEl.checked);
    wrap.classList.toggle('border-success', !!inputEl.checked);
    wrap.classList.toggle('rounded', !!inputEl.checked);
    wrap.classList.toggle('px-2', !!inputEl.checked);
    wrap.classList.toggle('py-2', !!inputEl.checked);
  }

  document.getElementById('ra-btn-brigade') && document.getElementById('ra-btn-brigade').addEventListener('click', function() {
    if (this.disabled) return;
    var btn = this;
    postForm('/patients/' + patientId + '/triage/actions/red_arrest/brigade', '', function(response) {
      btn.disabled = true;
      btn.classList.add('d-none');
      brigadeCalled = true;
      var card = document.getElementById('brigade-timer-card');
      if (card) {
        card.classList.remove('d-none');
        var timer = document.getElementById('brigade-timer');
        if (timer && response.brigade_timer_ends_at) {
          timer.dataset.timerEndsAt = response.brigade_timer_ends_at;
        }
      }
      var team = document.getElementById('ra-team-block');
      if (team) {
        team.classList.remove('d-none');
        team.querySelectorAll('input[type="checkbox"]').forEach(function(cb) {
          if (!cb.checked) cb.disabled = false;
        });
      }
      refreshCompleteState(response.can_complete);
    });
  });

  document.querySelectorAll('.ra-toggle').forEach(function(cb) {
    cb.addEventListener('change', function() {
      if (this.disabled) return;
      var group = this.dataset.group;
      var key = this.dataset.key;
      var checked = this.checked;
      var body = 'group=' + encodeURIComponent(group) + '&key=' + encodeURIComponent(key) + '&checked=' + (checked ? 'true' : 'false');
      var self = this;
      postForm('/patients/' + patientId + '/triage/actions/red_arrest/toggle', body, function(response) {
        paintToggleState(self);
        refreshSequentialAdrenaline();
        refreshCompleteState(response.can_complete);
      });
    });
  });

  document.querySelectorAll('.ra-vital').forEach(function(inp) {
    inp.addEventListener('blur', function() {
      if (this.disabled) return;
      var key = this.dataset.key;
      var value = this.value.trim();
      var last = (this.getAttribute('data-last-sent') || '').trim();
      if (value === last) return;
      var body = 'key=' + encodeURIComponent(key) + '&value=' + encodeURIComponent(value);
      var self = this;
      postForm('/patients/' + patientId + '/triage/actions/red_arrest/vital', body, function(response) {
        self.setAttribute('data-last-sent', value);
        refreshSequentialVitals();
        refreshCompleteState(response.can_complete);
      });
    });
  });

  document.querySelectorAll('.ra-vital').forEach(function(inp) {
    inp.addEventListener('input', refreshSequentialVitals);
  });

  document.querySelectorAll('.ra-vital-choice').forEach(function(inp) {
    inp.addEventListener('change', function() {
      if (this.disabled || !this.checked) return;
      var body = 'key=' + encodeURIComponent(this.dataset.key) + '&value=' + encodeURIComponent(this.value);
      postForm('/patients/' + patientId + '/triage/actions/red_arrest/vital', body, function(response) {
        refreshCompleteState(response.can_complete);
      });
    });
  });

  document.querySelectorAll('.ra-outcome').forEach(function(inp) {
    inp.addEventListener('change', function() {
      if (this.disabled || !this.checked) return;
      var selectedKey = this.dataset.key;
      var bodySet = 'group=manip&key=' + encodeURIComponent(selectedKey) + '&checked=true';
      var self = this;
      postForm('/patients/' + patientId + '/triage/actions/red_arrest/toggle', bodySet, function(response) {
        document.querySelectorAll('.ra-outcome').forEach(function(radio) {
          paintToggleState(radio);
        });
        paintToggleState(self);
        setCompleteEnabled(!!response.can_complete);
      });
    });
  });

  document.getElementById('ra-complete-btn') && document.getElementById('ra-complete-btn').addEventListener('click', function() {
    if (this.disabled) return;
    var xhr = new XMLHttpRequest();
    xhr.open('POST', '/patients/' + patientId + '/triage/actions/complete', true);
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    xhr.onload = function() {
      if (xhr.status === 200) location.reload();
    };
    var ap = actionsPerformerParam();
    xhr.send(ap || '');
  });

  setInterval(updateTimers, 1000);
  refreshSequentialVitals();
  refreshSequentialAdrenaline();
  refreshCompleteState();
  updateTimers();
})();
</script>
